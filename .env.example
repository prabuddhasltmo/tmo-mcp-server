# ── TMO API ───────────────────────────────────────────────────────────────────
# Company-wide credentials — all authenticated users share these
TMO_TOKEN=your_tmo_api_token
TMO_DATABASE=your_tmo_database_name
TMO_REGION=us

# ── Microsoft 365 OAuth ───────────────────────────────────────────────────────
# From Azure portal → App registrations → your app
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your_client_secret_here

# Public URL of this deployed server (no trailing slash)
BASE_URL=https://tmo-mcp.up.railway.app

# Optional: restrict to one email domain (e.g. yourcompany.com)
# Leave blank to allow any Microsoft 365 account
ALLOWED_DOMAIN=yourcompany.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Named profiles (local stdio / Claude Code mode only) ─────────────────────
TMO_TOKEN_PROD=ABS WEB
TMO_DATABASE_PROD=001-5533-000-AM Team
TMO_REGION_PROD=us
